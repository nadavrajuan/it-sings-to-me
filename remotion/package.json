{
  "name": "@looli/remotion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "studio": "remotion studio src/index.ts",
    "render:vertical": "remotion render src/index.ts Vertical out/it-sings-to-me-vertical.mp4 --concurrency=4",
    "render:horizontal": "remotion render src/index.ts Horizontal out/it-sings-to-me-horizontal.mp4 --concurrency=4",
    "render:both": "npm run render:vertical && npm run render:horizontal"
  },
  "dependencies": {
    "@remotion/cli": "4",
    "@remotion/google-fonts": "4",
    "remotion": "4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "typescript": "^5.4.5"
  }
}
